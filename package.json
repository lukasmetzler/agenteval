{
	"name": "agenteval",
	"version": "0.7.2",
	"description": "Measure whether your AI coding instructions actually make agents perform better",
	"type": "module",
	"keywords": [
		"cli",
		"ai",
		"testing",
		"evaluation",
		"claude",
		"copilot",
		"instructions",
		"agents",
		"lint",
		"benchmark"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/lukasmetzler/agenteval.git"
	},
	"author": "Lukas Metzler",
	"homepage": "https://github.com/lukasmetzler/agenteval",
	"bugs": {
		"url": "https://github.com/lukasmetzler/agenteval/issues"
	},
	"license": "MIT",
	"bin": {
		"agenteval": "./src/cli.ts"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "bun build src/cli.ts --compile --outfile=agenteval",
		"build:linux": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile=agenteval-linux-x64",
		"build:darwin": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile=agenteval-darwin-arm64",
		"build:darwin-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile=agenteval-darwin-x64",
		"test": "bun test",
		"test:unit": "bun test tests/unit/",
		"test:integration": "bun test tests/integration/",
		"lint": "biome check --write .",
		"lint:ci": "biome ci .",
		"typecheck": "tsc --noEmit",
		"check": "bun run lint:ci && bun run typecheck && bun run test"
	},
	"dependencies": {
		"chalk": "5.6.2",
		"commander": "14.0.3",
		"glob": "11.1.0",
		"js-tiktoken": "1.0.21",
		"mdast-util-to-string": "4.0.0",
		"minimatch": "10.2.5",
		"remark-frontmatter": "5.0.0",
		"remark-parse": "11.0.0",
		"unified": "11.0.5",
		"yaml": "2.8.3",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/bun": "1.3.11",
		"typescript": "5.9.3"
	}
}
