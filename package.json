{
	"name": "agenteval",
	"version": "0.1.2",
	"type": "module",
	"bin": {
		"agenteval": "./src/cli.ts"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "bun build src/cli.ts --compile --outfile=agenteval",
		"build:linux": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile=agenteval-linux-x64",
		"build:darwin": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile=agenteval-darwin-arm64",
		"test": "bun test",
		"test:unit": "bun test tests/unit/",
		"test:integration": "bun test tests/integration/",
		"lint": "biome check --write .",
		"lint:ci": "biome ci .",
		"typecheck": "tsc --noEmit",
		"check": "bun run lint:ci && bun run typecheck && bun run test"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"js-tiktoken": "^1.0.21",
		"unified": "^11.0.5",
		"remark-parse": "^11.0.0",
		"remark-frontmatter": "^5.0.0",
		"mdast-util-to-string": "^4.0.0",
		"yaml": "^2.8.3",
		"zod": "^3.24.0",
		"chalk": "^5.4.1",
		"glob": "^11.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "latest",
		"typescript": "^5.7.0"
	}
}
